{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug: ThreadLoom",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/bin/ThreadLoom.exe",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "console": "integratedTerminal",
            "preLaunchTask": "CMake: Build (Debug)",
            "visualizerFile": "${workspaceFolder}/.vscode/ThreadLoom.natvis"
        },
        {
            "name": "Debug: Attach to Process",
            "type": "cppvsdbg",
            "request": "attach",
            "processId": "${command:pickProcess}"
        }
    ]
}
